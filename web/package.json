{
  "name": "spectrafit-benchmark-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SpectraFit benchmark report UI — Vite + React; fetches the report from the FastAPI app at runtime.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:html": "NODE_OPTIONS=--max-old-space-size=4096 BUILD_HTML=1 vite build",
    "typecheck": "tsc --noEmit",
    "contract": "openapi-typescript http://localhost:8000/openapi.json -o src/openapi.gen.ts",
    "check:contract": "node scripts/check-openapi-sync.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "vitest run"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.16",
    "d3-format": "^3.1.0",
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-format": "^3.0.4",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.2",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.8"
  }
}
